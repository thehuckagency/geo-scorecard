# Copy to .env.local for dev, or set in Vercel project settings for prod.

# --- AI engines ---
# Leave BOTH engines blank to run in automatic MOCK mode (synthetic results,
# no spend) so the full flow works before wiring live keys.
PERPLEXITY_API_KEY=
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Force synthetic results even when keys are present (for demos).
MOCK_MODE=

# --- Site crawling (optional but recommended) ---
# Firecrawl is used as a FALLBACK only, when a plain fetch of the hotel's site
# is blocked by bot protection (Cloudflare etc.). It improves the GEO score
# reliability and the auto-suggested questions for those sites. Without it, the
# crawl is direct-only. Get a key at firecrawl.dev.
FIRECRAWL_API_KEY=

# --- Job store (REQUIRED in production) ---
# The worker and the status poll are separate serverless invocations, so they
# MUST share state via Redis. Use Upstash (create a DB, copy the REST creds) or
# Vercel KV (which injects the KV_REST_API_* pair the store also reads).
# Without this, only local `next dev` works (in-memory fallback).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Email the scorecard to the lead (Resend) ---
# Create an API key at resend.com and verify a sending domain (add the DNS
# records Resend gives you). Leave RESEND_API_KEY blank to skip emailing.
RESEND_API_KEY=
# From address on a verified domain, e.g. "Huck <scorecard@huck.agency>".
RESEND_FROM=
# Optional: replies go here (a real inbox), e.g. hello@huck.agency
RESEND_REPLY_TO=

# --- Lead capture + links ---
# Where the completed scorecard JSON is POSTed (CRM / Airtable / Zapier hook).
LEAD_WEBHOOK_URL=
# Public links used in the UI (safe to expose).
NEXT_PUBLIC_BOOKING_URL=https://www.huck.agency
NEXT_PUBLIC_PRIVACY_URL=https://www.huck.agency/privacy

# --- Internal worker auth ---
# Random string; start route and worker route must share it. Defaults to a dev
# value locally, but SET THIS in production.
INTERNAL_SECRET=
